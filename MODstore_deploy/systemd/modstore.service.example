# 示例：MODstore FastAPI API worker（多进程，无后台任务）
# 与 sync-modstore-to-server 默认树 /root/modstore-git/MODstore_deploy 一致。
#
# 安装：复制为 /etc/systemd/system/modstore.service
# 或用 scripts/align_modstore_systemd_to_deploy.sh 写 drop-in。
#
# 依赖项：modstore-scheduler.service 必须单独运行（处理 outbox + 订阅续费）。
# 多实例 Nginx LB：另见 modstore@.service.example。
#
# systemctl enable --now modstore

[Unit]
Description=MODstore FastAPI API workers
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/modstore-git/MODstore_deploy
EnvironmentFile=-/root/modstore-git/MODstore_deploy/.env
Environment=PYTHONUNBUFFERED=1
# API worker 不运行 outbox / APScheduler（由 modstore-scheduler.service 负责）
Environment=MODSTORE_RUN_BACKGROUND_JOBS=0
# 跨 worker 事件总线使用 RabbitMQ（默认 memory 不跨进程）
Environment=MODSTORE_BUS=rabbitmq
# PAYMENT_BACKEND 须为 java 才能保证防重放 nonce 跨 worker 一致（Redis 实现）
# Environment=PAYMENT_BACKEND=java
ExecStart=/root/modstore-git/MODstore_deploy/.venv/bin/python -m uvicorn modstore_server.app:app --host 0.0.0.0 --port 9999 --workers 4
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
