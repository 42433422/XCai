# MODstore production example for single-server Docker Compose.
# Copy to .env on the server and replace every CHANGE_ME value.

POSTGRES_DB=modstore
POSTGRES_USER=modstore
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_POSTGRES_PASSWORD
POSTGRES_PORT=5432

REDIS_PASSWORD=CHANGE_ME_LONG_RANDOM_REDIS_PASSWORD
REDIS_PORT=6379

RABBITMQ_USER=modstore
RABBITMQ_PASSWORD=CHANGE_ME_LONG_RANDOM_RABBITMQ_PASSWORD
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

MODSTORE_API_PORT=8765
MODSTORE_MARKET_PORT=4173
JAVA_PAYMENT_PORT=8080
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_LONG_RANDOM_GRAFANA_PASSWORD

PAYMENT_BACKEND=java
JAVA_PAYMENT_SERVICE_URL=http://payment-service:8080
PAYMENT_PROXY_CONNECT_TIMEOUT_SECONDS=5
PAYMENT_PROXY_READ_TIMEOUT_SECONDS=30

MODSTORE_JWT_SECRET=CHANGE_ME_AT_LEAST_32_BYTES_RANDOM
MODSTORE_ADMIN_RECHARGE_TOKEN=CHANGE_ME_ADMIN_TOKEN
PAYMENT_SECRET_KEY=CHANGE_ME_PAYMENT_SIGNING_SECRET
MODSTORE_PUBLIC_ORIGIN=https://your-domain.example
MODSTORE_MARKET_PREFIX=/market

CORS_ORIGINS=https://your-domain.example,https://www.your-domain.example
CORS_ORIGIN_REGEX=none

MODSTORE_EMAIL_DEBUG=0
MODSTORE_SMTP_HOST=smtp.qq.com
MODSTORE_SMTP_PORT=465
MODSTORE_SMTP_USER=CHANGE_ME
MODSTORE_SMTP_PASSWORD=CHANGE_ME
MODSTORE_SENDER_EMAIL=CHANGE_ME
MODSTORE_SENDER_NAME=MODstore

ALIPAY_APP_ID=CHANGE_ME
ALIPAY_PRIVATE_KEY_PATH=/secrets/alipay/app_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=/secrets/alipay/alipay_public_key.pem
ALIPAY_NOTIFY_URL=https://your-domain.example/api/payment/notify/alipay
ALIPAY_DEBUG=false

WECHATPAY_APP_ID=
WECHATPAY_MCH_ID=
WECHATPAY_PRIVATE_KEY_PATH=
WECHATPAY_MERCHANT_SERIAL_NO=
WECHATPAY_API_V3_KEY=
WECHATPAY_NOTIFY_URL=

MODSTORE_WEBHOOK_URL=
MODSTORE_WEBHOOK_SECRET=
MODSTORE_WEBHOOK_TIMEOUT_SECONDS=5
MODSTORE_WEBHOOK_RETRIES=2

FLYWAY_ENABLED=true
JPA_DDL_AUTO=validate
MODSTORE_VECTOR_BACKEND=chroma

LOADTEST_BASE_URL=http://market
LOADTEST_WS_URL=ws://market
K6_STAGE=smoke
