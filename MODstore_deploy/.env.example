# MODstore 服务器配置
# 复制本文件到 MODstore_deploy 根目录，命名为 .env 后填写（.env 已加入 .gitignore，勿提交）

# ════════════════════════════════════════
# 支付宝支付配置
# ════════════════════════════════════════

# 支付宝应用 ID（开放平台创建应用后获得）
ALIPAY_APP_ID=

# 应用私钥（RSA2 格式，PEM 字符串，\n 换行）
# 或在支付宝开放平台生成后填写
ALIPAY_APP_PRIVATE_KEY=

# 支付宝公钥（注意：不是应用公钥！在开放平台上传应用公钥后获得）
ALIPAY_ALIPAY_PUBLIC_KEY=

# 异步通知回调地址（必须是公网可访问的 HTTPS URL）
# 路径必须是 /api/payment/notify/alipay
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/notify/alipay

# 沙箱模式：1 表示使用支付宝沙箱环境，生产环境必须删除或设为 0
ALIPAY_DEBUG=1

# 支付完成回跳：浏览器从支付宝回到前端的绝对地址前缀（协议 + 域名，无尾斜杠）。
# 留空则使用当前请求的 Host（本地一般为 http://127.0.0.1:8765）
# MODSTORE_PUBLIC_ORIGIN=https://your-domain.com
# 前端路由前缀（与 Vite base 一致，默认 /market）
# MODSTORE_MARKET_PREFIX=/market

# ════════════════════════════════════════
# 公网部署配置
# ════════════════════════════════════════

# CORS 允许的域名（逗号分隔），留空则使用本地开发默认地址
# 公网部署请设置为你的前端域名，例如：
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
CORS_ORIGINS=

# JWT 密钥（生产环境必须设置一个长随机字符串）
# MODSTORE_JWT_SECRET=your-random-secret-key-here

# 管理员线下直充 Token（须通过请求头 X-Modstore-Recharge-Token 或 JSON 字段 recharge_token 传入）
# MODSTORE_ADMIN_RECHARGE_TOKEN=your-admin-recharge-token

# ════════════════════════════════════════
# 邮箱验证码（注册 / 邮箱登录）
# ════════════════════════════════════════
# 使用 QQ 邮箱发信：在 QQ 邮箱设置中开启 SMTP，并生成「授权码」作为密码（非 QQ 登录密码）。
#
# MODSTORE_SMTP_HOST=smtp.qq.com
# MODSTORE_SMTP_PORT=465
# MODSTORE_SMTP_USER=你的QQ号@qq.com
# MODSTORE_SMTP_PASSWORD=SMTP授权码
# MODSTORE_SENDER_EMAIL=你的QQ号@qq.com
# MODSTORE_SENDER_NAME=XC AGI
#
# 本地调试不写 SMTP 时，设为 1 则不发真实邮件，验证码会打印在运行 uvicorn 的控制台：
# MODSTORE_EMAIL_DEBUG=1
