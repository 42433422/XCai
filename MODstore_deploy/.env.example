# MODstore 服务器配置
# 复制本文件为 .env 后填写真实值（.env 不会被提交到 Git）

# ════════════════════════════════════════
# 邮箱验证码配置（QQ邮箱）
# ════════════════════════════════════════
# 1. 登录 https://mail.qq.com
# 2. 设置 → 账户 → 开启「POP3/SMTP服务」
# 3. 生成「授权码」（16位，不是QQ登录密码）

MODSTORE_SMTP_HOST=smtp.qq.com
MODSTORE_SMTP_PORT=465
MODSTORE_SMTP_USER=970882904@qq.com
MODSTORE_SMTP_PASSWORD=your-qq-smtp-password
MODSTORE_SENDER_EMAIL=970882904@qq.com
MODSTORE_SENDER_NAME=XC AGI

# 调试模式：设为 1 则验证码打印在控制台，不发送真实邮件
MODSTORE_EMAIL_DEBUG=1

# ════════════════════════════════════════
# 安全密钥
# ════════════════════════════════════════
# JWT 密钥（生产环境必须设置长随机字符串）
MODSTORE_JWT_SECRET=your-random-secret-key-change-in-production

# 管理员线下直充 Token（用于给用户充值余额）
MODSTORE_ADMIN_RECHARGE_TOKEN=your-admin-token-change-this

# ════════════════════════════════════════
# CORS 跨域配置
# ════════════════════════════════════════
# 本地开发默认地址
CORS_ORIGINS=http://localhost:5176,http://127.0.0.1:5176,http://localhost:4173,http://127.0.0.1:4173

# 生产环境示例（部署后改为你的域名）：
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ════════════════════════════════════════
# 公网部署配置（可选）
# ════════════════════════════════════════
# 支付完成回跳地址前缀（协议+域名，无尾斜杠）
# MODSTORE_PUBLIC_ORIGIN=https://your-domain.com

# 前端路由前缀（与 Vite base 一致，默认 /market）
# MODSTORE_MARKET_PREFIX=/market

# ════════════════════════════════════════
# 支付后端切换（Python 兼容代理 → Java）
# ════════════════════════════════════════
# 设为 java 后，FastAPI 网关把 /api/payment、/api/wallet、/api/refunds
# 透传给 Java 支付服务；Python 本地 payment_orders/alipay_service 仅作只读兜底。
# 默认（python）保留旧行为，便于本地开发或灰度回滚。
PAYMENT_BACKEND=python
JAVA_PAYMENT_SERVICE_URL=http://127.0.0.1:8080
